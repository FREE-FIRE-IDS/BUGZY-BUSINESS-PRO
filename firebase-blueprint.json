
{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the SaaS system",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "device_ids": { "type": "array", "items": { "type": "string" } },
        "license_key": { "type": "string" },
        "trial_start": { "type": "string", "format": "date-time" },
        "companies": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["email"]
    },
    "License": {
      "title": "License",
      "description": "A license for the SaaS system",
      "type": "object",
      "properties": {
        "license_key": { "type": "string" },
        "owner_email": { "type": "string", "format": "email" },
        "device_ids": { "type": "array", "items": { "type": "string" }, "description": "Max 2 devices" },
        "expires_at": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "expired", "suspended"] }
      },
      "required": ["license_key", "owner_email"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Users collection"
    },
    "licenses": {
      "schema": "License",
      "description": "Licenses collection"
    }
  }
}
