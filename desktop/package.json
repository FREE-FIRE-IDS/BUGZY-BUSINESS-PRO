{
  "name": "bugzy-business-pro",
  "version": "1.0.0",
  "description": "Bugzy Business Pro Desktop App",
  "main": "main.js",
  "author": "Bugzy",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "publish": "electron-builder --win -p always"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.bugzy.business.pro",
    "productName": "Bugzy Business Pro",
    "copyright": "Copyright © 2026 Bugzy",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "FREE-FIRE-IDS",
        "repo": "BUGZY-BUSINESS-PRO"
      }
    ]
  }
}
